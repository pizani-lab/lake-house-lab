# Django
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (metadata only — data lives in Parquet/DuckDB)
DATABASE_URL=postgres://lakehouse:lakehouse@db:5432/lakehouse

# Redis / Celery
CELERY_BROKER_URL=redis://redis:6379/0

# LLM Provider: "anthropic" (padrão) ou "ollama"
LLM_PROVIDER=anthropic

# Anthropic (usado quando LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Ollama (usado quando LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# LakeHouse paths
DATA_DIR=/data
BRONZE_DIR=/data/bronze
SILVER_DIR=/data/silver
GOLD_DIR=/data/gold
DUCKDB_PATH=/data/lakehouse.duckdb

# dbt
DBT_PROJECT_DIR=/app/dbt_project
DBT_PROFILES_DIR=/app/dbt_project
